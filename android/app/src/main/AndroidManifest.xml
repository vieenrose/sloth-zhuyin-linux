<?xml version="1.0" encoding="utf-8"?>
<!--
  Slothing IME — ONYX BOOX Tab Mini C, Android 11 (API 30), arm64-v8a.
  The package/namespace (com.slothing.ime) is set in app/build.gradle.kts.

  An IME is a bound Service: the framework binds it under the system-only
  BIND_INPUT_METHOD permission, finds it via the "android.view.InputMethod"
  intent action, and reads its capabilities from the "android.view.im"
  meta-data -> res/xml/method.xml. See
  https://developer.android.com/develop/ui/views/touch-and-input/creating-input-method#define-ime
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@drawable/ic_launcher"
        android:supportsRtl="false"
        android:theme="@android:style/Theme.Material.Light">

        <!-- The input method service. -->
        <service
            android:name=".SlothingImeService"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Launcher + settings screen: deep-links to the system input-method
             settings (enable) and the IME picker (switch to Slothing). Also the
             IME's android:settingsActivity target (method.xml). -->
        <activity
            android:name=".EnableActivity"
            android:label="@string/settings_name"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
